3304947912693024, 0.04303649812936783, -0.014393056742846966, -0.0064915623515844345, 0.02014188840985298, -0.029742853716015816, -0.025882326066493988, -0.02581518515944481, -0.015761027112603188, -0.03212631121277809, 0.029658928513526917, 0.04095517098903656, 0.006197826471179724, 0.05680012330412865, -0.019604770466685295, -0.017724860459566116, 0.010205223225057125, 0.026805495843291283, -0.031454913318157196, 0.011858535930514336, -0.023146385326981544, -0.005341796204447746, 0.0954725444316864, 0.008018989115953445, 0.0052872453816235065, 0.020997917279601097, 0.03182418271899223, 0.017758430913090706, 0.11346596479415894, -0.021283261477947235, 0.013075442053377628, -0.01723809912800789, 0.009223305620253086, -0.035080455243587494, -0.003451396245509386, 0.006609057076275349, 0.019067654386162758, -0.01365452166646719, -0.017825569957494736, 0.007972830906510353, 0.013948257081210613, 0.03783318027853966], 'text_index': 0}]}, 'usage': {'total_tokens': 71}, 'request_id': '45f30309-421b-43f8-b676-c08afda6f1fe'}
